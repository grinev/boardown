{
  "name": "boardown",
  "version": "0.1.0",
  "private": true,
  "publisher": "boardown",
  "displayName": "boardown",
  "description": "A lightweight, local-first task board stored as markdown inside your repo.",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/grinev/boardown.git"
  },
  "homepage": "https://github.com/grinev/boardown#readme",
  "bugs": {
    "url": "https://github.com/grinev/boardown/issues"
  },
  "keywords": [
    "board",
    "kanban",
    "markdown",
    "tasks",
    "scrum"
  ],
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "boardown.openBoard",
        "title": "boardown: Open board"
      }
    ]
  },
  "scripts": {
    "build:host": "node esbuild.mjs",
    "build:webview": "vite build",
    "build": "pnpm build:host && pnpm build:webview",
    "watch:host": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "typecheck": "tsc --noEmit",
    "vscode:prepublish": "pnpm build",
    "package": "node -e \"require('fs').mkdirSync('build',{recursive:true})\" && vsce package --no-dependencies --out build/"
  },
  "dependencies": {
    "@boardown/core": "workspace:*",
    "@boardown/ui": "workspace:*",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vscode/vsce": "^3.9.1",
    "esbuild": "^0.24.0",
    "vite": "^6.0.3"
  }
}
