{
  "name": "@boardown/vscode",
  "version": "0.0.0",
  "private": true,
  "displayName": "boardown",
  "description": "A lightweight, local-first task board stored as markdown inside your repo.",
  "main": "./dist/extension.js",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "contributes": {
    "commands": [
      {
        "command": "boardown.openBoard",
        "title": "boardown: Open board"
      }
    ]
  },
  "scripts": {
    "build:host": "node esbuild.mjs",
    "build:webview": "vite build",
    "build": "pnpm build:host && pnpm build:webview",
    "watch:host": "node esbuild.mjs --watch",
    "watch:webview": "vite build --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/vscode": "^1.90.0",
    "@vitejs/plugin-react": "^4.3.4",
    "esbuild": "^0.24.0",
    "vite": "^6.0.3"
  }
}
