# --- Dependencies ---
node_modules/
.pnpm-store/

# --- Build output ---
dist/
build/
out/
*.tsbuildinfo
*.vsix

# electron-builder reads its app icons from this dir (committed input
# resources, generated by `pnpm icons`); only the release/ output is ignored.
!/packages/electron/build/

# --- Vite ---
.vite/
vite.config.*.timestamp-*

# --- Test / coverage ---
coverage/
.nyc_output/

# Playwright MCP scratch output (snapshots, screenshots, console logs)
.playwright-mcp/

# --- Caches ---
.cache/
.turbo/
.eslintcache
.stylelintcache

# --- Logs ---
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Environment / secrets ---
.env
.env.*
!.env.example

# --- OS ---
.DS_Store
Thumbs.db
desktop.ini

# --- Editors / IDEs ---
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
*.swp
*.swo

# --- AI assistants (local-only state, not for commit) ---

# Claude Code
.claude/
CLAUDE.local.md

# OpenAI Codex
.codex/

# OpenCode
.opencode/

# Cursor
.cursor/
.cursorignore.local

# Kilo Code
.kilocode/
